# Backend API (optional on Vercel if vercel.json proxies /api → Render)
# Omit VITE_API_URL to use same-origin /api (recommended with proxy).
# Or set full URL; with or without /api suffix both work.
# VITE_API_URL=https://your-service.onrender.com

# Cloudinary — get these from cloudinary.com > Dashboard
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=velora_uploads
